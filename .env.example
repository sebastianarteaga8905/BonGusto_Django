DATABASE_URL=postgresql://usuario:password@host:5432/bongustofi
DJANGO_SECRET_KEY=CAMBIA_ESTA_CLAVE_SUPER_SECRETA
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=.railway.app,.up.railway.app
CSRF_TRUSTED_ORIGINS=https://tu-app.up.railway.app
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@bongusto.local

REDIS_URL=redis://127.0.0.1:6379/1
CACHE_DEFAULT_TIMEOUT_SECONDS=300
CACHE_KEY_PREFIX=bongusto
CHANNEL_CAPACITY=300
CHANNEL_EXPIRY_SECONDS=30

API_TOKEN_TTL_SECONDS=28800
PASSWORD_RESET_CODE_TTL_MINUTES=10
