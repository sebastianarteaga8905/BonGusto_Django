DATABASE_URL=postgresql://usuario:password@host:5432/bongustofi
DJANGO_SECRET_KEY=CAMBIA_ESTA_CLAVE_SUPER_SECRETA
DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
CSRF_TRUSTED_ORIGINS=https://tu-app.up.railway.app
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

EMAIL_DELIVERY_PROVIDER=resend
RESEND_API_KEY=resend_api_key_aqui
RESEND_FROM_EMAIL=BonGusto <onboarding@resend.dev>
DEFAULT_FROM_EMAIL=BonGusto <onboarding@resend.dev>
SERVER_EMAIL=BonGusto <onboarding@resend.dev>

# Alternativa SMTP si algun entorno no usa Resend API
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=correo_oficial_de_bongusto@gmail.com
EMAIL_HOST_PASSWORD=google_app_password_aqui

REDIS_URL=redis://127.0.0.1:6379/1
CACHE_DEFAULT_TIMEOUT_SECONDS=300
CACHE_KEY_PREFIX=bongusto
